tmp=$(mktemp)

git for-each-ref \
  --sort=-committerdate \
  --format='%(committerdate:short) %(refname:short)' \
  refs/remotes/origin \
| grep -vE ' origin/(HEAD|main|master|develop|dev)$' \
| fzf -m \
| awk '{print $2}' \
| sed 's#^origin/##' \
> "$tmp"

echo "即将删除这些远程分支："
cat "$tmp"

echo
read -p "确认删除？输入 yes 继续，其他任意输入取消: " ok

if [ "$ok" = "yes" ]; then
  xargs -r -I{} git push origin --delete {} < "$tmp"
else
  echo "已取消"
fi

rm -f "$tmp"
